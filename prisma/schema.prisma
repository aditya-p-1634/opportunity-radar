// Opportunity Radar — Production Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth compatible) ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          String    @default("USER") // USER | ADMIN | MODERATOR
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  bookmarks     Bookmark[]
  applications  Application[]
  notifications Notification[]
  searchHistory SearchHistory[]
  eligibilityRecords EligibilityRecord[]
  recommendationScores RecommendationScore[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Profile ──────────────────────────────────────────────────────────────────

model Profile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  university            String?
  degree                String?  // Bachelors | Masters | PhD | Dual
  branch                String?
  year                  Int?
  cgpa                  Float?
  maxCgpa               Float    @default(10)
  skills                String   @default("[]") // JSON array
  programmingLanguages  String   @default("[]") // JSON array
  researchInterests     String   @default("[]") // JSON array
  preferredCountries    String   @default("[]") // JSON array
  preferredInstitutions String   @default("[]") // JSON array of institution IDs
  resumeUrl             String?
  portfolioUrl          String?
  githubUrl             String?
  linkedinUrl           String?
  bio                   String?
  completionPercent     Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Institutions ─────────────────────────────────────────────────────────────

model Institution {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortName        String?
  type             String   // UNIVERSITY | RESEARCH_LAB | INDUSTRY | GOVERNMENT | NONPROFIT
  country          String
  state            String?
  city             String?
  website          String?
  logoUrl          String?
  overview         String?
  researchAreas    String   @default("[]") // JSON array
  prestigeScore    Float    @default(50) // 0-100
  verified         Boolean  @default(false)
  crawlUrl         String?
  lastCrawledAt    DateTime?
  crawlStatus      String   @default("IDLE") // IDLE | RUNNING | SUCCESS | FAILED
  opportunityCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  departments  Department[]
  opportunities Opportunity[]
  crawlerJobs  CrawlerJob[]
}

model Department {
  id            String @id @default(cuid())
  institutionId String
  name          String
  website       String?
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)

  @@index([institutionId])
}

// ─── Opportunities ────────────────────────────────────────────────────────────

model Opportunity {
  id              String    @id @default(cuid())
  institutionId   String
  title           String
  slug            String    @unique
  type            String    // RESEARCH_INTERNSHIP | SUMMER_SCHOOL | SCHOLARSHIP | FELLOWSHIP | HACKATHON | COMPETITION | CONFERENCE | JOB | OTHER
  description     String
  researchArea    String?
  eligibilityText String?
  minDegree       String?   // HIGH_SCHOOL | BACHELORS | MASTERS | PHD
  maxDegree       String?
  branches        String    @default("[]") // JSON array
  minCgpa         Float?
  minYear         Int?
  maxYear         Int?
  funding         String?   // FULL | PARTIAL | STIPEND | UNPAID | NONE
  fundingAmount   String?
  location        String?
  country         String?
  state           String?
  mode            String    @default("ONSITE") // ONSITE | REMOTE | HYBRID
  duration        String?
  durationWeeks   Int?
  deadline        DateTime?
  startDate       DateTime?
  endDate         DateTime?
  officialUrl     String?
  applicationUrl  String?
  verified        Boolean   @default(false)
  status          String    @default("ACTIVE") // ACTIVE | CLOSED | DRAFT | ARCHIVED
  popularityScore Float     @default(0)
  viewCount       Int       @default(0)
  applyCount      Int       @default(0)
  saveCount       Int       @default(0)
  sourceUrl       String?
  sourceHash      String?   @unique // for deduplication
  discoveredVia   String?   @default("MANUAL")
  crawledAt       DateTime?
  publishedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  institution          Institution           @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  bookmarks            Bookmark[]
  applications         Application[]
  eligibilityRecords   EligibilityRecord[]
  recommendationScores RecommendationScore[]

  @@index([institutionId])
  @@index([type])
  @@index([deadline])
  @@index([status])
  @@index([country])
  @@index([verified])
  @@index([publishedAt])
}

// ─── User Actions ─────────────────────────────────────────────────────────────

model Bookmark {
  id            String   @id @default(cuid())
  userId        String
  opportunityId String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([userId])
}

model Application {
  id            String   @id @default(cuid())
  userId        String
  opportunityId String
  status        String   @default("APPLIED") // APPLIED | IN_PROGRESS | SUBMITTED | ACCEPTED | REJECTED | WITHDRAWN
  notes         String?
  appliedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([userId])
}

// ─── Eligibility & Recommendations ────────────────────────────────────────────

model EligibilityRecord {
  id            String   @id @default(cuid())
  userId        String
  opportunityId String
  status        String   // ELIGIBLE | LIKELY | POSSIBLY | NOT_ELIGIBLE
  score         Float    // 0-100
  reasons       String   @default("[]") // JSON array of reason strings
  computedAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([userId])
  @@index([status])
}

model RecommendationScore {
  id            String   @id @default(cuid())
  userId        String
  opportunityId String
  score         Float    // 0-100
  rank          Int?
  factors       String   @default("{}") // JSON: { eligibility, profileMatch, research, skills, popularity, funding, prestige, deadline, freshness }
  reasons       String   @default("[]") // JSON array of explanation tags
  computedAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
  @@index([userId, score])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // DEADLINE | NEW_MATCH | INSTITUTION_UPDATE | SAVED_REMINDER | SYSTEM
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  emailSent Boolean  @default(false)
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

// ─── Search ───────────────────────────────────────────────────────────────────

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String
  query     String
  filters   String   @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Crawler System ───────────────────────────────────────────────────────────

model CrawlerJob {
  id            String    @id @default(cuid())
  institutionId String?
  name          String
  status        String    @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED | CANCELLED
  startedAt     DateTime?
  finishedAt    DateTime?
  itemsFound    Int       @default(0)
  itemsAdded    Int       @default(0)
  itemsUpdated  Int       @default(0)
  itemsSkipped  Int       @default(0)
  errorMessage  String?
  createdAt     DateTime  @default(now())
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  logs          CrawlerLog[]

  @@index([status])
  @@index([createdAt])
}

model CrawlerLog {
  id        String   @id @default(cuid())
  jobId     String
  level     String   // INFO | WARN | ERROR | DEBUG
  message   String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())
  job       CrawlerJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ─── System ───────────────────────────────────────────────────────────────────

model SystemMetric {
  id        String   @id @default(cuid())
  key       String
  value     Float
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}
